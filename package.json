{
  "name": "monolith",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "vite",
    "dev:php": "php -S localhost:8000 -t public",
    "build": "vite build",
    "preview": "vite preview",
    "db:start": "spindb start monolith 2>/dev/null || spindb create monolith -e mariadb -d monolith -p 3306 --start",
    "db:setup": "node scripts/db-setup.mjs && node scripts/migrate.mjs",
    "db:migrate": "node scripts/migrate.mjs",
    "db:stop": "spindb stop monolith",
    "db:status": "spindb info monolith",
    "test": "composer test",
    "lint": "composer lint",
    "format": "composer format",
    "tunnel": "ngrok http 8000"
  },
  "dependencies": {
    "alpinejs": "^3.14.9"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "ngrok": "5.0.0-beta.2",
    "postcss": "^8.5.6",
    "spindb": "^0.61.2",
    "tailwindcss": "^3.4.17",
    "vite": "^6.3.5"
  }
}
