{
  "name": "monolith/app",
  "description": "Monolith — permission-gated internal tools platform",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": "^8.3",
    "ext-json": "*",
    "ext-pdo": "*",
    "auth0/auth0-php": "^8.19",
    "guzzlehttp/guzzle": "^7.13",
    "http-interop/http-factory-guzzle": "^1.2",
    "vlucas/phpdotenv": "^5.6"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.5",
    "squizlabs/php_codesniffer": "^4.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "BudgetTracker\\": "packages/budget-tracker/src/",
      "CursorShare\\": "packages/cursor-share/src/",
      "Devtools\\": "packages/devtools/src/",
      "Stickies\\": "packages/stickies/src/",
      "Tunnels\\": "packages/tunnels/src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "php scripts/run-tests.php",
    "test:unit": "vendor/bin/phpunit",
    "lint": "phpcs --standard=phpcs.xml",
    "lint:fix": "phpcbf --standard=phpcs.xml",
    "format": "@lint:fix"
  },
  "config": {
    "sort-packages": true
  }
}
