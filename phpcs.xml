<?xml version="1.0"?>
<ruleset name="Monolith">
    <description>Monolith PHP style — PSR-12</description>

    <file>app</file>
    <file>config</file>
    <file>routes</file>
    <file>public/index.php</file>
    <file>scripts</file>
    <file>tests</file>
    <file>packages</file>

    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/var/*</exclude-pattern>
    <exclude-pattern>*/resources/views/*</exclude-pattern>

    <arg name="extensions" value="php"/>
    <arg value="ps"/>
    <arg value="n"/>
    <arg value="s"/>

    <rule ref="PSR12"/>

    <!-- PHPUnit test methods use snake_case (test_foo_bar) -->
    <rule ref="PSR1.Methods.CamelCapsMethodName">
        <exclude-pattern>*/tests/*</exclude-pattern>
    </rule>
</ruleset>
